# ============================================================
# 疗心舍 · 生产环境部署配置
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 填入实际的值（不要删除注释）
# 3. 这些变量会在 Vercel 构建时注入
# ============================================================

# --------- 阿里云 DashScope（通义千问）---------
# API Key 获取：https://dashscope.console.aliyun.com/apiKey
# 生产环境建议使用 qwen-plus 或更高版本以获得更好的回复质量
VITE_DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 模型版本：qwen-turbo（快）| qwen-plus（平衡）| qwen-max（高质量）
# 推荐生产环境用 qwen-plus
VITE_DASHSCOPE_MODEL=qwen-plus

# --------- 后端 AI 代理服务 ---------
# 如果你有自己的 Node.js 后端代理服务，填在这里
# 没有后端代理？留空即可，前端会直接调用 DashScope API
VITE_BACKEND_API_URL=https://your-backend.railway.app

# --------- Supabase（云端记忆存储）---------
# 获取地址：https://supabase.com/dashboard/project/_/settings/api
# 填入 Project URL 和 anon/public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGcOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------- 访问暗号（安全防护）---------
# 前端和后端需保持一致，用于防止 API 被滥用
# 推荐：使用一个只有你和 AI 知道的短句
VITE_ACCESS_CODE=你春天时相信的那句话

# ============================================================
# 安全检查清单
# ============================================================
# [ ] VITE_DASHSCOPE_API_KEY  已填入（不得为空）
# [ ] VITE_SUPABASE_URL       已填入
# [ ] VITE_SUPABASE_ANON_KEY  已填入
# [ ] VITE_ACCESS_CODE        已填入，且前后端一致
# [ ] VITE_BACKEND_API_URL    若有后端则填入，否则留空
#
# 部署前请在 Vercel 控制台确认：
#   Settings → Environment Variables → 添加以上所有变量
# ============================================================