# Preview Environment (Vercel Preview Deployments)
NODE_ENV=production
VITE_APP_TITLE=疗心舍 - Preview
VITE_API_BASE_URL=https://api.xxx.com
VITE_PORT=3000

# Backend AI Service Configuration
VITE_BACKEND_API_URL=https://your-backend-domain.com
VITE_DASHSCOPE_MODEL=qwen-turbo

# AI Configuration (Legacy - for reference)
VITE_AI_API_KEY=your-production-api-key-here
VITE_AI_BASE_URL=https://api.openai.com/v1
VITE_AI_MODEL=gpt-3.5-turbo

# Enable VConsole for debugging API calls in preview deployments
VITE_ENABLE_VCONSOLE=true