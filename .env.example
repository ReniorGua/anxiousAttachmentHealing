# ===========================================
# 复制此文件为 .env.development 或 .env.production
# 并填入你的实际 API Key
# ===========================================

# 阿里云 DashScope API Key
# 获取地址：https://dashscope.console.aliyun.com/apiKey
VITE_DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 通义千问模型版本
# 可选：qwen-turbo, qwen-plus, qwen-max, qwen-max-longcontext
VITE_DASHSCOPE_MODEL=qwen-turbo

# 后端代理服务地址
VITE_BACKEND_API_URL=http://localhost:3000

# Supabase 配置
# 获取地址：https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
