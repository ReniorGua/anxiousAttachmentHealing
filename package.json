{
  "name": "healing-rest-return",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Vue3 + Vite + TypeScript Business Admin Template",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"cd server && npm run dev\" \"npm run dev\"",
    "dev:server": "cd server && npm run dev",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:fix": "eslint src --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,js,ts,json,css,scss,md}\"",
    "type-check": "vue-tsc --noEmit",
    "install:server": "cd server && npm install",
    "test:backend": "node scripts/test-backend.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/vue": "^3.0.116",
    "@supabase/supabase-js": "^2.103.2",
    "@vueuse/core": "^13.8.0",
    "ai": "^6.0.116",
    "axios": "^1.9.0",
    "pinia": "^3.0.4",
    "vconsole": "^3.15.1",
    "vue": "^3.5.25",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.1.5"
  }
}
